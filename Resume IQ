<script>
pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
const PDFJS_CMAP_URL='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/cmaps/';
const PDFJS_FONT_URL='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/standard_fonts/';

const API_KEY='YOUR_API_KEY_HERE'; // ← paste your Anthropic key

let selectedRole='Software Engineer';
let currentMode='ats'; // 'ats' | 'recruiter'
let uploadedFile=null;
let resumeText='';
let currentAnalysis=null;
let recruiterData=null;
let chatHistory=[];
let currentOptTab='diff';

// Mode toggle
function setMode(m){
  currentMode=m;
  document.getElementById('modeAts').classList.toggle('active',m==='ats');
  document.getElementById('modeRec').classList.toggle('active',m==='recruiter');
