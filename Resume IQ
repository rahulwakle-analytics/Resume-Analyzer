  document.getElementById('analyseBtn').textContent=m==='recruiter'?'Run Recruiter Analysis →':'Analyse Resume →';
}

// Role chips
document.querySelectorAll('.role-chip').forEach(chip=>{
  if(chip.closest('#quickPrompts')) return;
  chip.addEventListener('click',()=>{
    document.querySelectorAll('.role-section .role-chip').forEach(c=>c.classList.remove('active'));
    chip.classList.add('active');
    if(chip.dataset.role==='Custom'){
      document.getElementById('customWrap').style.display='block';
      selectedRole=document.getElementById('customRoleInput').value||'Custom Role';
    } else {
      document.getElementById('customWrap').style.display='none';
      selectedRole=chip.dataset.role;
    }
  });
});
document.getElementById('customRoleInput').addEventListener('input',e=>{selectedRole=e.target.value||'Custom Role'});

// Upload
const zone=document.getElementById('uploadZone'),fi=document.getElementById('fileInput');
zone.addEventListener('click',()=>fi.click());
zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('drag-over')});
zone.addEventListener('dragleave',()=>zone.classList.remove('drag-over'));
zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f&&f.type==='application/pdf')setFile(f)});
fi.addEventListener('change',()=>{if(fi.files[0])setFile(fi.files[0])});
document.getElementById('fileRemove').addEventListener('click',removeFile);

function setFile(f){
  uploadedFile=f;
  document.getElementById('fileName').textContent=f.name;
  document.getElementById('fileSize').textContent=(f.size/1024).toFixed(0)+' KB';
  document.getElementById('filePill').classList.add('show');
  document.getElementById('analyseBtn').disabled=false;
}
function removeFile(){
  uploadedFile=null;fi.value='';
  document.getElementById('filePill').classList.remove('show');
  document.getElementById('analyseBtn').disabled=true;
}

document.getElementById('analyseBtn').addEventListener('click',analyse);
document.getElementById('reanalyseBtn').addEventListener('click',()=>{
  document.getElementById('results').classList.remove('show');
  document.getElementById('uploadSection').style.display='block';
  document.getElementById('improvePanel').style.display='none';
  document.getElementById('improveBtn').disabled=false;
  currentAnalysis=null;recruiterData=null;resumeText='';chatHistory=[];
  document.getElementById('chatMsgs').innerHTML=`<div class="chat-msg"><div class="chat-avatar avatar-ai">🎯</div><div class="chat-bubble bubble-ai">Hi! I'm your AI Recruiter. I've analysed this resume end to end. Ask me anything — fit assessment, salary benchmarks, red flags, interview strategies, or how to position this candidate.</div></div>`;
  removeFile();
});

async function extractText(file){
  const ab=await file.arrayBuffer();
  const pdf=await pdfjsLib.getDocument({data:ab,cMapUrl:PDFJS_CMAP_URL,cMapPacked:true,standardFontDataUrl:PDFJS_FONT_URL}).promise;
  let t='';
  for(let i=1;i<=pdf.numPages;i++){const p=await pdf.getPage(i);const c=await p.getTextContent();t+=c.items.map(s=>s.str).join(' ')+'\n';}
  return t;
}

async function callAI(messages,maxTokens=1500){
  const r=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json','x-api-key':API_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
    body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:maxTokens,messages})
  });
  const data=await r.json();
  if(data.error)throw new Error(data.error.message);
  return data.content.map(b=>b.text||'').join('');
}

const ATS_STEPS=['Parsing resume structure…','Extracting skills & experience…','Matching role requirements…','Scoring ATS compatibility…','Preparing results…'];
const REC_STEPS=['Reading resume like a hiring manager…','Extracting candidate profile…','Evaluating against role criteria…','Identifying gaps & red flags…','Generating recruiter report…','Preparing interview questions…'];

async function analyse(){
  if(!uploadedFile)return;
  document.getElementById('uploadSection').style.display='none';
  document.getElementById('loadingState').classList.add('show');
  document.getElementById('loadingSteps').innerHTML='';

  try{resumeText=await extractText(uploadedFile);}catch{resumeText='';}

  const steps=currentMode==='recruiter'?REC_STEPS:ATS_STEPS;
  document.getElementById('loadingTxt').textContent=currentMode==='recruiter'?'Running recruiter analysis…':'Analysing your resume…';

  let si=0;
  const iv=setInterval(()=>{
    if(si<steps.length){
      const s=document.createElement('div');s.className='step';s.textContent='✓ '+steps[si++];
      document.getElementById('loadingSteps').appendChild(s);setTimeout(()=>s.classList.add('done'),80);
    }
  },800);

  const jd=document.getElementById('jdInput').value.trim();

  // ATS analysis (always run)
  const atsPrompt=`You are an expert ATS resume analyser. Analyse this resume for the role: "${selectedRole}".
${jd?`\nJob Description:\n"""\n${jd.slice(0,2000)}\n"""`:''} 

Resume:
"""
${resumeText.slice(0,5000)}
"""

Reply ONLY with valid JSON, no markdown fences:
{
  "ats_score":<0-100>,
  "score_label":"Poor"|"Fair"|"Good"|"Strong"|"Excellent",
  "score_description":"<2 sentences>",
  "metrics":{"keyword_match":<0-100>,"format_score":<0-100>,"experience_relevance":<0-100>},
  "keywords_present":["<up to 12>"],
  "keywords_missing":["<up to 12>"],
  "jd_keywords":${jd?'["<keywords from JD not in resume, up to 8>"]':'[]'},
  "strengths":["<3-5>"],
  "improvements":["<4-6>"],
  "critical_issues":["<0-3>"]
}`;

  let recruiterPrompt='';
  if(currentMode==='recruiter'){
    recruiterPrompt=`You are a senior technical recruiter with 15 years of hiring experience. Evaluate this candidate for the role: "${selectedRole}".
${jd?`\nJob Description:\n"""\n${jd.slice(0,2000)}\n"""`:''} 

Resume:
"""
${resumeText.slice(0,5000)}
"""

Act as a real recruiter making a hiring decision. Reply ONLY with valid JSON, no markdown fences:
{
  "verdict":"Strong Hire"|"Lean Hire"|"Maybe"|"Lean Pass"|"Pass",
  "verdict_reason":"<2-3 sentence hiring decision rationale>",
  "candidate_summary":"<3-4 sentence professional summary of this candidate>",
  "scores":{
    "technical_fit":<0-100>,
    "experience_level":<0-100>,
    "communication_clarity":<0-100>,
    "career_progression":<0-100>
  },
  "years_experience":<estimated number>,
  "seniority_level":"Junior"|"Mid"|"Senior"|"Staff"|"Principal"|"Lead",
  "salary_range":"<e.g. $80k–$100k or ₹12–18 LPA based on profile>",
  "top_strengths":["<3-4 specific recruiting selling points>"],
  "red_flags":["<2-4 genuine concerns a recruiter would notice>"],
  "missing_for_role":["<3-5 skills/experience gaps vs the role>"],
  "interview_questions":[
    {"question":"<question>","why":"<why a recruiter asks this>","tag":"Technical"|"Behavioural"|"Gap Probe"}
  ],
  "overall_recommendation":"<1 paragraph honest recruiter recommendation — include both positives and concerns>"
}
Generate 5-6 interview_questions covering technical, behavioural, and gap probes.`;
  }

  let d=null, rd=null;
  try{
    const raw=await callAI([{role:'user',content:atsPrompt}],1500);
    d=JSON.parse(raw.replace(/```json|```/g,'').trim());
  }catch(e){
    d={ats_score:55,score_label:'Fair',score_description:'Could not reach API — check your key.',
      metrics:{keyword_match:50,format_score:60,experience_relevance:55},
      keywords_present:['Communication','Teamwork'],keywords_missing:['Agile','Docker','AWS'],
      jd_keywords:[],strengths:['Contact info present'],improvements:['Add keywords','Quantify achievements'],critical_issues:[]};
  }

  if(currentMode==='recruiter'){
    try{
      const raw2=await callAI([{role:'user',content:recruiterPrompt}],2000);
      rd=JSON.parse(raw2.replace(/```json|```/g,'').trim());
    }catch(e){
      rd={verdict:'Maybe',verdict_reason:'Could not reach API for recruiter analysis.',candidate_summary:'N/A',
        scores:{technical_fit:60,experience_level:55,communication_clarity:65,career_progression:60},
        years_experience:3,seniority_level:'Mid',salary_range:'N/A',
        top_strengths:['Resume uploaded'],red_flags:['API key missing'],missing_for_role:['N/A'],
        interview_questions:[{question:'Tell me about yourself.',why:'Standard opener.',tag:'Behavioural'}],
        overall_recommendation:'Please add a valid API key to get the full recruiter report.'};
    }
  }

  clearInterval(iv);
  currentAnalysis=d;recruiterData=rd;

  // Prime chat history
  chatHistory=[{role:'user',content:`Here is the resume I want you to analyse as a senior recruiter for the role of ${selectedRole}:\n\n${resumeText.slice(0,4000)}\n\n${jd?`Job Description:\n${jd.slice(0,1500)}`:''}${rd?`\n\nYour recruiter analysis:\n${JSON.stringify(rd)}`:''}${d?`\n\nATS analysis:\n${JSON.stringify(d)}`:''}\n\nYou are now acting as a senior recruiter. The user will ask you questions about this candidate. Answer as an experienced hiring professional — be direct, insightful, and honest.`},
    {role:'assistant',content:`Understood. I've reviewed the full resume and all analysis data. I'm ready to answer your questions about this candidate as a senior recruiter. Ask away!`}];

  document.getElementById('loadingState').classList.remove('show');
  renderResults(d,rd);
}

function renderResults(d,rd){
  // Show/hide recruiter tab
  if(currentMode==='recruiter'){
    document.getElementById('rnav-rec').style.display='flex';
    document.getElementById('tab-rec').querySelector('.recruiter-panel').classList.add('show');
    renderRecruiter(rd);
  }

  // ATS Score ring
  const score=d.ats_score,circ=264,arc=document.getElementById('scoreArc');
  const col=score>=75?'#3DD68C':score>=50?'#F0A742':'#F06060';
  arc.style.stroke=col;
  setTimeout(()=>{arc.style.strokeDashoffset=circ-(score/100)*circ},100);
  const numEl=document.getElementById('scoreNum');numEl.style.color=col;
  let cur=0;const iv=setInterval(()=>{cur=Math.min(cur+2,score);numEl.textContent=cur;if(cur>=score)clearInterval(iv)},16);
  document.getElementById('scoreRole').textContent=selectedRole.toUpperCase();
  document.getElementById('scoreLabel').textContent=d.score_label;
  document.getElementById('scoreLabel').style.color=col;
  document.getElementById('scoreDesc').textContent=d.score_description;

  // Metrics
  const mr=document.getElementById('metricsRow');mr.innerHTML='';
  [{k:'keyword_match',l:'Keyword Match'},{k:'format_score',l:'Format Score'},{k:'experience_relevance',l:'Relevance'}].forEach(m=>{
    const v=d.metrics[m.k]||0,c=v>=75?'var(--green)':v>=50?'var(--amber)':'var(--red)';
    mr.innerHTML+=`<div class="metric-card"><div class="metric-lbl">${m.l}</div><div class="metric-val" style="color:${c}">${v}</div><div class="metric-bar"><div class="metric-bar-fill" style="width:0%;background:${c}" data-w="${v}%"></div></div></div>`;
  });
  setTimeout(()=>document.querySelectorAll('.metric-bar-fill').forEach(b=>b.style.width=b.dataset.w),200);

  // Accordion
  const sc=document.getElementById('sectionsContainer');sc.innerHTML='';
  const secs=[];
  if(d.critical_issues?.length) secs.push({ico:'⚠',title:'Critical Issues',badge:`${d.critical_issues.length} Issues`,cls:'bg-red',open:true,body:iList(d.critical_issues,'dot-r')});
  secs.push({ico:'✓',title:'Strengths',badge:`${d.strengths.length} Found`,cls:'bg-green',open:false,body:iList(d.strengths,'dot-g')});
  secs.push({ico:'→',title:'Improvements Needed',badge:`${d.improvements.length} Actions`,cls:'bg-amber',open:true,body:iList(d.improvements,'dot-a')});
  const jdKw=d.jd_keywords||[];
  secs.push({ico:'#',title:'Keyword Analysis',badge:`${d.keywords_present.length}/${d.keywords_present.length+d.keywords_missing.length} Matched`,cls:d.keywords_present.length>=d.keywords_missing.length?'bg-green':'bg-amber',open:false,body:kwHTML(d.keywords_present,d.keywords_missing,jdKw)});

  secs.forEach((s,i)=>{
    const div=document.createElement('div');div.className='section';
    div.innerHTML=`<div class="sec-head ${s.open?'is-open':''}" id="sh${i}" onclick="tSec(${i})"><span class="sec-ico">${s.ico}</span><span class="sec-title">${s.title}</span><span class="sec-badge ${s.cls}">${s.badge}</span><span class="sec-chev ${s.open?'is-open':''}" id="chev${i}">▼</span></div><div class="sec-body ${s.open?'is-open':''}" id="sb${i}">${s.body}</div>`;
    sc.appendChild(div);
  });

  document.getElementById('results').classList.add('show');
  showResultTab('ats');
}

function renderRecruiter(rd){
  if(!rd)return;
  const verdictCls={'Strong Hire':'vb-hire','Lean Hire':'vb-hire','Maybe':'vb-maybe','Lean Pass':'vb-pass','Pass':'vb-pass'};
  const verdictIcon={'Strong Hire':'✅','Lean Hire':'👍','Maybe':'🤔','Lean Pass':'⚠️','Pass':'❌'};
  const cls=verdictCls[rd.verdict]||'vb-maybe';
  const ico=verdictIcon[rd.verdict]||'🤔';

  let html=`
  <div class="verdict-banner ${cls}">
    <div class="vb-icon">${ico}</div>
    <div>
      <div class="vb-title" style="color:${cls==='vb-hire'?'var(--green)':cls==='vb-maybe'?'var(--amber)':'var(--red)'}">${rd.verdict}</div>
      <div class="vb-desc">${esc(rd.verdict_reason)}</div>
    </div>
  </div>

  <div style="background:var(--navy-1);border:1px solid var(--navy-2);border-radius:10px;padding:16px 20px;margin-bottom:14px">
    <div class="metric-lbl" style="margin-bottom:8px">Candidate Summary</div>
    <div style="font-size:13px;color:var(--cream-dim);line-height:1.7">${esc(rd.candidate_summary)}</div>
    <div style="margin-top:10px;display:flex;gap:16px;flex-wrap:wrap">
      <span style="font-size:12px;color:var(--muted)">⏱ ~${rd.years_experience} yrs exp</span>
      <span style="font-size:12px;color:var(--muted)">📊 ${rd.seniority_level}</span>
      <span style="font-size:12px;color:var(--gold)">💰 ${esc(rd.salary_range)}</span>
    </div>
  </div>

  <div class="rec-scores">
    ${Object.entries(rd.scores||{}).map(([k,v])=>{
      const label=k.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
      const c=v>=75?'var(--green)':v>=50?'var(--amber)':'var(--red)';
      return `<div class="rec-score-card"><div class="rsc-label">${label}</div><div class="rsc-val" style="color:${c}">${v}</div><div class="metric-bar"><div class="metric-bar-fill" style="width:${v}%;background:${c}"></div></div></div>`;
    }).join('')}
  </div>`;

  // Accordion sections
  const recSecs=[
    {ico:'💪',title:'Recruiter Selling Points',badge:`${(rd.top_strengths||[]).length} Points`,cls:'bg-green',open:true,body:iList(rd.top_strengths||[],'dot-g')},
    {ico:'🚩',title:'Red Flags',badge:`${(rd.red_flags||[]).length} Flags`,cls:'bg-red',open:true,body:iList(rd.red_flags||[],'dot-r')},
    {ico:'📋',title:'Missing for This Role',badge:`${(rd.missing_for_role||[]).length} Gaps`,cls:'bg-amber',open:false,body:iList(rd.missing_for_role||[],'dot-a')},
  ];

  recSecs.forEach((s,i)=>{
    const idx='rec'+i;
    html+=`<div class="section"><div class="sec-head ${s.open?'is-open':''}" id="sh${idx}" onclick="tSecId('${idx}')"><span class="sec-ico">${s.ico}</span><span class="sec-title">${s.title}</span><span class="sec-badge ${s.cls}">${s.badge}</span><span class="sec-chev ${s.open?'is-open':''}" id="chev${idx}">▼</span></div><div class="sec-body ${s.open?'is-open':''}" id="sb${idx}">${s.body}</div></div>`;
  });

  // Interview Questions
  const qs=rd.interview_questions||[];
  if(qs.length){
    const tagCls={'Technical':'tag-blue','Behavioural':'tag-amber','Gap Probe':'tag-red'};
    html+=`<div class="section"><div class="sec-head is-open" id="shreciq" onclick="tSecId('reciq')"><span class="sec-ico">❓</span><span class="sec-title">Suggested Interview Questions</span><span class="sec-badge bg-blue">${qs.length} Questions</span><span class="sec-chev is-open" id="chevreciq">▼</span></div><div class="sec-body is-open" id="sbreciq"><div class="iq-list">${qs.map(q=>`<div class="iq-item"><span class="iq-tag ${tagCls[q.tag]||'tag-blue'}">${esc(q.tag)}</span><div class="iq-q">${esc(q.question)}</div><div class="iq-why">Why ask: ${esc(q.why)}</div></div>`).join('')}</div></div></div>`;
  }

  // Overall recommendation
  html+=`<div style="background:var(--navy-1);border:1px solid var(--navy-2);border-radius:10px;padding:16px 20px;margin-top:8px"><div class="metric-lbl" style="margin-bottom:8px">Overall Recommendation</div><div style="font-size:13px;color:var(--cream-dim);line-height:1.7">${esc(rd.overall_recommendation)}</div></div>`;

  document.getElementById('recruiterContent').innerHTML=html;
}

// Nav tabs
function showResultTab(tab){
  ['ats','opt','rec','chat'].forEach(t=>{
    document.getElementById('tab-'+t).style.display=t===tab?'block':'none';
    const btn=document.getElementById('rnav-'+t);
    if(btn) btn.classList.toggle('active',t===tab);
  });
}

function tSec(i){
  document.getElementById('sb'+i).classList.toggle('is-open');
  document.getElementById('chev'+i).classList.toggle('is-open');
  document.getElementById('sh'+i).classList.toggle('is-open');
}
function tSecId(id){
  document.getElementById('sb'+id).classList.toggle('is-open');
  document.getElementById('chev'+id).classList.toggle('is-open');
  document.getElementById('sh'+id).classList.toggle('is-open');
}
function iList(items,dc){
  return items.map(t=>`<div class="item"><div class="dot ${dc}"></div><div>${esc(t)}</div></div>`).join('');
}
function kwHTML(present,missing,jd){
  let html=`<div class="kw-lbl">Present ✓</div><div class="kw-list">${present.map(k=>`<span class="kw kw-yes">${k}</span>`).join('')}</div>`;
  html+=`<div class="kw-lbl">Missing — add these</div><div class="kw-list">${missing.map(k=>`<span class="kw kw-no">${k}</span>`).join('')}</div>`;
  if(jd&&jd.length) html+=`<div class="kw-lbl">From JD — not in resume</div><div class="kw-list">${jd.map(k=>`<span class="kw kw-jd">${k}</span>`).join('')}</div>`;
  return html;
}

// OPTIMISE
async function improveResume(){
  if(!currentAnalysis)return;
  document.getElementById('improveBtn').disabled=true;
  document.getElementById('improvePanel').style.display='block';
  document.getElementById('impLoading').classList.add('show');
  document.getElementById('diffPane').classList.remove('show');
  document.getElementById('fullPane').classList.remove('show');

  const impr=(currentAnalysis.improvements||[]).join('\n- ');
  const miss=[...(currentAnalysis.keywords_missing||[]),...(currentAnalysis.jd_keywords||[])].join(', ');

  const prompt=`You are an expert resume writer and ATS specialist.

Original resume for the role of "${selectedRole}":
"""
${resumeText.slice(0,5000)}
"""

ATS improvements needed:
- ${impr}

Missing keywords to weave in naturally: ${miss}

Reply ONLY with valid JSON, no markdown fences:
{
  "changes":[{"section":"<Summary/Skills/Experience etc>","before":"<original or 'Not present'>","after":"<improved>"}],
  "full_rewritten":"<complete improved resume as clean plain text>"
}

Rules: never change employers/dates/degrees/facts. Only improve wording, add keywords naturally, quantify with [X%] if unknown, add summary if missing, use clean ATS-friendly structure.`;

  try{
    const raw=await callAI([{role:'user',content:prompt}],2500);
    const data=JSON.parse(raw.replace(/```json|```/g,'').trim());
    const dp=document.getElementById('diffPane');dp.innerHTML='';
    (data.changes||[]).forEach(ch=>{
      const s=document.createElement('div');s.className='diff-sec';
      s.innerHTML=`<div class="diff-sec-title">${esc(ch.section)}</div><div class="diff-lbl" style="color:var(--red)">Before</div><div class="diff-before">${esc(ch.before)}</div><div class="diff-lbl" style="color:var(--green)">After</div><div class="diff-after">${esc(ch.after)}</div>`;
      dp.appendChild(s);
    });
    document.getElementById('rewrittenText').value=data.full_rewritten||'';
  }catch(e){
    document.getElementById('diffPane').innerHTML=`<div style="padding:20px;color:var(--red);font-size:13px;">⚠ Could not generate — check your API key.<br><small style="color:var(--muted)">${esc(e.message)}</small></div>`;
  }
  document.getElementById('impLoading').classList.remove('show');
  switchOptTab(currentOptTab);
}

function switchOptTab(t){
  currentOptTab=t;
  document.getElementById('tabDiff').classList.toggle('active',t==='diff');
  document.getElementById('tabFull').classList.toggle('active',t==='full');
  document.getElementById('diffPane').classList.toggle('show',t==='diff');
  document.getElementById('fullPane').classList.toggle('show',t==='full');
}

function copyResume(){
  const t=document.getElementById('rewrittenText');t.select();document.execCommand('copy');
  const btn=document.querySelector('.btn-copy');btn.textContent='✓ Copied!';
  setTimeout(()=>btn.textContent='📋 Copy to Clipboard',2000);
}

// CHAT
async function sendChat(){
  const inp=document.getElementById('chatInput');
  const msg=inp.value.trim();
  if(!msg||!chatHistory.length)return;
  inp.value='';
  document.getElementById('chatSendBtn').disabled=true;

  appendChat('user',msg);
  chatHistory.push({role:'user',content:msg});
  document.getElementById('typingIndicator').classList.add('show');

  try{
    const raw=await callAI(chatHistory,800);
    chatHistory.push({role:'assistant',content:raw});
    document.getElementById('typingIndicator').classList.remove('show');
    appendChat('ai',raw);
  }catch(e){
    document.getElementById('typingIndicator').classList.remove('show');
    appendChat('ai','Sorry, I could not reach the API right now. Please check your key.');
  }
  document.getElementById('chatSendBtn').disabled=false;
}

function quickAsk(q){document.getElementById('chatInput').value=q;sendChat();}

function appendChat(role,text){
  const msgs=document.getElementById('chatMsgs');
  const div=document.createElement('div');
  div.className='chat-msg'+(role==='user'?' user':'');
  div.innerHTML=`<div class="chat-avatar ${role==='ai'?'avatar-ai':'avatar-user'}">${role==='ai'?'🎯':'👤'}</div><div class="chat-bubble ${role==='ai'?'bubble-ai':'bubble-user'}">${esc(text).replace(/\n/g,'<br>')}</div>`;
  msgs.appendChild(div);
  msgs.scrollTop=msgs.scrollHeight;
}

function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
</script>
