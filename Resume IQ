<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ResumeIQ — ATS + Recruiter AI</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --navy:#0D1117;--navy-1:#161B22;--navy-2:#21262D;--navy-3:#30363D;--navy-4:#484F58;
  --cream:#F5F0E8;--cream-1:#EDE8DF;--cream-dim:#B8B0A0;
  --gold:#D4A84B;--gold-lt:#F0C96A;
  --green:#3DD68C;--amber:#F0A742;--red:#F06060;--blue:#58A6FF;
  --text:#F5F0E8;--muted:#8B949E;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--navy);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;line-height:1.6;min-height:100vh;-webkit-font-smoothing:antialiased;overflow-x:hidden}
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.4}
.app{position:relative;z-index:1;max-width:860px;margin:0 auto;padding:52px 24px 100px}

/* HEADER */
header{text-align:center;margin-bottom:48px}
.wordmark{display:inline-flex;align-items:center;gap:8px;margin-bottom:24px}
.wdot{width:7px;height:7px;border-radius:50%;background:var(--gold);box-shadow:0 0 8px var(--gold)}
.wtxt{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--cream-dim)}
.hero-title{font-size:clamp(26px,5vw,50px);font-weight:800;line-height:1.08;margin-bottom:12px;color:var(--cream);letter-spacing:-0.5px}
.hero-title span{color:var(--gold)}
.hero-sub{font-size:13px;color:var(--muted);max-width:500px;margin:0 auto}

/* MODE TOGGLE */
.mode-toggle{display:flex;background:var(--navy-1);border:1px solid var(--navy-3);border-radius:12px;padding:5px;gap:5px;margin-bottom:32px}
.mode-btn{flex:1;padding:10px 16px;border-radius:8px;border:none;background:transparent;color:var(--muted);font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:7px}
.mode-btn.active{background:var(--navy-2);color:var(--cream);font-weight:600;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
.mode-btn span.badge{font-size:10px;background:var(--gold);color:var(--navy);padding:1px 6px;border-radius:4px;font-weight:700}

/* DIVIDER */
.divider{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.divider-line{flex:1;height:1px;background:var(--navy-3)}
.divider-label{font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--navy-4);white-space:nowrap}

/* ROLE */
.role-section{margin-bottom:24px}
.role-categories{display:flex;flex-direction:column;gap:12px}
.role-cat-label{font-size:10px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--navy-4);margin-bottom:7px}
.role-grid{display:flex;flex-wrap:wrap;gap:6px}
.role-chip{padding:5px 12px;border-radius:6px;border:1px solid var(--navy-3);background:var(--navy-1);color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;transition:all 0.18s;font-family:'Inter',sans-serif;user-select:none}
.role-chip:hover{border-color:var(--gold);color:var(--cream)}
.role-chip.active{border-color:var(--gold);background:rgba(212,168,75,0.1);color:var(--gold);font-weight:600}
.custom-role-wrap{margin-top:8px}
.custom-role-wrap input{width:100%;background:var(--navy-1);border:1px solid var(--navy-3);border-radius:8px;padding:9px 14px;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;outline:none;transition:border-color 0.2s}
.custom-role-wrap input:focus{border-color:var(--gold)}
.custom-role-wrap input::placeholder{color:var(--navy-4)}

/* JD INPUT (Recruiter mode) */
.jd-section{margin-bottom:24px}
.jd-textarea{width:100%;min-height:140px;background:var(--navy-1);border:1px solid var(--navy-3);border-radius:10px;padding:14px;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;line-height:1.7;outline:none;resize:vertical;transition:border-color 0.2s}
.jd-textarea:focus{border-color:var(--gold)}
.jd-textarea::placeholder{color:var(--navy-4)}
.jd-hint{font-size:11px;color:var(--navy-4);margin-top:6px}

/* UPLOAD */
.upload-zone{border:1.5px dashed var(--navy-3);border-radius:14px;padding:44px 32px;text-align:center;cursor:pointer;transition:all 0.22s;background:var(--navy-1);position:relative;overflow:hidden;margin-bottom:14px}
.upload-zone::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% -20%, rgba(212,168,75,0.06) 0%, transparent 65%);pointer-events:none}
.upload-zone:hover,.upload-zone.drag-over{border-color:var(--gold);background:rgba(212,168,75,0.03)}
.upload-icon-wrap{width:48px;height:48px;border:1px solid var(--navy-3);border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;background:var(--navy-2);font-size:20px;transition:border-color 0.22s}
.upload-zone:hover .upload-icon-wrap{border-color:var(--gold)}
.upload-title{font-size:15px;font-weight:600;color:var(--cream);margin-bottom:5px}
.upload-sub{font-size:12px;color:var(--muted)}
.upload-sub em{color:var(--gold);font-style:normal}
#fileInput{display:none}
.file-pill{display:none;align-items:center;gap:10px;padding:10px 14px;background:var(--navy-2);border:1px solid var(--navy-3);border-radius:8px;margin-bottom:14px;font-size:13px}
.file-pill.show{display:flex}
.file-pill-name{font-weight:500;flex:1;color:var(--cream)}
.file-pill-size{color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:11px}
.file-pill-rm{cursor:pointer;color:var(--navy-4);font-size:14px;transition:color 0.2s;line-height:1}
.file-pill-rm:hover{color:var(--red)}

/* BUTTONS */
.btn-primary{width:100%;padding:14px 20px;border-radius:10px;border:none;background:var(--gold);color:var(--navy);font-family:'Inter',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all 0.22s;letter-spacing:0.2px}
.btn-primary:disabled{opacity:0.3;cursor:not-allowed}
.btn-primary:not(:disabled):hover{background:var(--gold-lt);box-shadow:0 8px 24px rgba(212,168,75,0.3);transform:translateY(-1px)}
.btn-outline{width:100%;padding:12px;border-radius:9px;border:1px solid var(--navy-3);background:transparent;color:var(--muted);font-family:'Inter',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;margin-top:16px}
.btn-outline:hover{border-color:var(--navy-4);color:var(--cream)}
.btn-gold-outline{width:100%;padding:13px 20px;border-radius:10px;border:1.5px solid var(--gold);background:transparent;color:var(--gold);font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.22s}
.btn-gold-outline:hover{background:rgba(212,168,75,0.08)}
.btn-gold-outline:disabled{opacity:0.35;cursor:not-allowed}

/* LOADING */
.loading-state{display:none;text-align:center;padding:80px 20px}
.loading-state.show{display:block}
.spinner{width:40px;height:40px;border:2px solid var(--navy-3);border-top-color:var(--gold);border-radius:50%;animation:spin 0.75s linear infinite;margin:0 auto 18px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-txt{font-size:13px;color:var(--muted);margin-bottom:18px}
.loading-steps{display:flex;flex-direction:column;gap:7px;align-items:center}
.step{font-size:12px;color:var(--muted);opacity:0;transition:all 0.35s}
.step.done{opacity:1;color:var(--green)}

/* RESULTS */
.results{display:none}
.results.show{display:block;animation:fadeUp 0.4s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* TABS (results nav) */
.results-nav{display:flex;background:var(--navy-1);border:1px solid var(--navy-2);border-radius:12px;padding:4px;gap:4px;margin-bottom:20px}
.rnav-btn{flex:1;padding:9px 12px;border-radius:8px;border:none;background:transparent;color:var(--muted);font-family:'Inter',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:5px}
.rnav-btn.active{background:var(--navy-2);color:var(--cream);font-weight:600}
.rnav-btn .dot-ind{width:6px;height:6px;border-radius:50%;background:var(--gold)}

/* SCORE HERO */
.score-hero{background:var(--cream);border-radius:16px;padding:28px 32px;margin-bottom:14px;display:flex;align-items:center;gap:28px;position:relative;overflow:hidden}
.score-hero::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,75,0.15) 0%,transparent 70%);pointer-events:none}
.score-ring{flex-shrink:0;position:relative;width:100px;height:100px}
.score-ring svg{width:100px;height:100px;transform:rotate(-90deg)}
.ring-bg{fill:none;stroke:var(--cream-1);stroke-width:8}
.ring-fill{fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1.3s cubic-bezier(0.4,0,0.2,1)}
.score-num-wrap{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.score-num-val{font-size:26px;font-weight:800;line-height:1;color:var(--navy)}
.score-num-of{font-size:10px;color:var(--navy-4);font-family:'JetBrains Mono',monospace}
.score-text{flex:1}
.score-for{font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--navy-4);margin-bottom:5px}
.score-verdict{font-size:20px;font-weight:800;color:var(--navy);margin-bottom:5px}
.score-desc{font-size:12px;color:var(--navy-4);line-height:1.6}

/* METRICS */
.metrics-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.metric-card{background:var(--navy-1);border:1px solid var(--navy-2);border-radius:10px;padding:16px}
.metric-lbl{font-size:10px;font-weight:600;letter-spacing:0.8px;text-transform:uppercase;color:var(--muted);margin-bottom:7px}
.metric-val{font-size:20px;font-weight:700;margin-bottom:7px}
.metric-bar{height:2px;background:var(--navy-3);border-radius:2px;overflow:hidden}
.metric-bar-fill{height:100%;border-radius:2px;transition:width 1s ease}

/* ACCORDION */
.section{margin-bottom:8px}
.sec-head{display:flex;align-items:center;gap:10px;padding:12px 16px;background:var(--navy-1);border:1px solid var(--navy-2);border-radius:9px;cursor:pointer;transition:background 0.18s;user-select:none}
.sec-head.is-open{border-radius:9px 9px 0 0;border-bottom-color:transparent}
.sec-head:hover{background:var(--navy-2)}
.sec-ico{font-size:14px;width:18px;text-align:center}
.sec-title{font-size:13px;font-weight:600;flex:1;color:var(--cream)}
.sec-badge{font-family:'JetBrains Mono',monospace;font-size:10px;padding:2px 8px;border-radius:4px;font-weight:500}
.bg-green{background:rgba(61,214,140,0.1);color:var(--green)}
.bg-amber{background:rgba(240,167,66,0.1);color:var(--amber)}
.bg-red{background:rgba(240,96,96,0.1);color:var(--red)}
.bg-blue{background:rgba(88,166,255,0.1);color:var(--blue)}
.sec-chev{color:var(--navy-4);font-size:10px;transition:transform 0.28s}
.sec-chev.is-open{transform:rotate(180deg)}
.sec-body{background:var(--navy-2);border:1px solid var(--navy-2);border-top:none;border-radius:0 0 9px 9px;padding:16px;display:none}
.sec-body.is-open{display:block}

.item{display:flex;gap:10px;margin-bottom:11px;padding-bottom:11px;border-bottom:1px solid var(--navy-3);font-size:13px;line-height:1.6;color:var(--cream-dim)}
.item:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:9px}
.dot-g{background:var(--green)}.dot-a{background:var(--amber)}.dot-r{background:var(--red)}.dot-b{background:var(--blue)}

.kw-lbl{font-size:10px;font-weight:600;letter-spacing:0.8px;text-transform:uppercase;color:var(--muted);margin-bottom:9px}
.kw-list{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
.kw{font-family:'JetBrains Mono',monospace;font-size:11px;padding:3px 9px;border-radius:4px;border:1px solid}
.kw-yes{border-color:rgba(61,214,140,0.3);color:var(--green);background:rgba(61,214,140,0.06)}
.kw-no{border-color:rgba(240,96,96,0.3);color:var(--red);background:rgba(240,96,96,0.06)}
.kw-jd{border-color:rgba(88,166,255,0.3);color:var(--blue);background:rgba(88,166,255,0.06)}

/* RECRUITER PANEL */
.recruiter-panel{display:none}
.recruiter-panel.show{display:block;animation:fadeUp 0.35s ease}

/* Verdict banner */
.verdict-banner{border-radius:12px;padding:20px 24px;margin-bottom:16px;display:flex;align-items:flex-start;gap:16px}
.vb-hire{background:rgba(61,214,140,0.08);border:1px solid rgba(61,214,140,0.25)}
.vb-maybe{background:rgba(240,167,66,0.08);border:1px solid rgba(240,167,66,0.25)}
.vb-pass{background:rgba(240,96,96,0.08);border:1px solid rgba(240,96,96,0.25)}
.vb-icon{font-size:28px;flex-shrink:0}
.vb-title{font-size:17px;font-weight:800;margin-bottom:4px}
.vb-desc{font-size:13px;color:var(--muted);line-height:1.6}

/* Recruiter score grid */
.rec-scores{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px}
.rec-score-card{background:var(--navy-1);border:1px solid var(--navy-2);border-radius:10px;padding:16px}
.rsc-label{font-size:10px;font-weight:600;letter-spacing:0.8px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.rsc-val{font-size:20px;font-weight:700;margin-bottom:4px}
.rsc-note{font-size:12px;color:var(--muted);line-height:1.5}

/* Interview questions */
.iq-list{display:flex;flex-direction:column;gap:10px}
.iq-item{background:var(--navy-3);border-radius:8px;padding:14px 16px}
.iq-q{font-size:13px;font-weight:600;color:var(--cream);margin-bottom:6px}
.iq-why{font-size:12px;color:var(--muted);line-height:1.5}
.iq-tag{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;margin-bottom:8px;font-family:'JetBrains Mono',monospace}
.tag-red{background:rgba(240,96,96,0.15);color:var(--red)}
.tag-amber{background:rgba(240,167,66,0.15);color:var(--amber)}
.tag-blue{background:rgba(88,166,255,0.15);color:var(--blue)}

/* OPTIMIZE PANEL */
.optimize-panel{margin-top:16px}
.opt-tabs{display:flex;gap:0;margin-bottom:0}
.opt-tab{padding:8px 16px;font-size:12px;font-weight:500;border:1px solid var(--navy-3);background:transparent;color:var(--muted);cursor:pointer;transition:all 0.18s;font-family:'Inter',sans-serif}
.opt-tab:first-child{border-radius:8px 0 0 0}
.opt-tab:last-child{border-radius:0 8px 0 0;border-left:none}
.opt-tab.active{background:var(--navy-2);color:var(--cream);border-color:var(--navy-2);font-weight:600}
.opt-body{background:var(--navy-1);border:1px solid var(--navy-2);border-radius:0 0 10px 10px;overflow:hidden}
.tab-pane{display:none}
.tab-pane.show{display:block}
.imp-loading{text-align:center;padding:40px;display:none}
.imp-loading.show{display:block}
.imp-loading p{font-size:13px;color:var(--muted);margin-top:10px}

/* diff */
.diff-sec{padding:18px 20px;border-bottom:1px solid var(--navy-2)}
.diff-sec:last-child{border-bottom:none}
.diff-sec-title{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.diff-lbl{font-size:11px;font-weight:500;margin-bottom:4px}
.diff-before,.diff-after{font-size:12px;line-height:1.75;padding:12px 14px;border-radius:7px;margin-bottom:8px;white-space:pre-wrap;word-break:break-word}
.diff-before{border-left:3px solid var(--red);background:rgba(240,96,96,0.05);color:#b0a0a0}
.diff-after{border-left:3px solid var(--green);background:rgba(61,214,140,0.05);color:#a0c0b0}

.full-view{padding:18px 20px}
.full-view textarea{width:100%;min-height:360px;background:var(--navy-2);border:1px solid var(--navy-3);border-radius:9px;padding:14px;color:var(--cream);font-size:12px;line-height:1.85;font-family:'Inter',sans-serif;outline:none;resize:vertical;transition:border-color 0.2s}
.full-view textarea:focus{border-color:var(--gold)}
.btn-copy{margin-top:10px;padding:8px 16px;border-radius:7px;border:1px solid var(--navy-3);background:var(--navy-2);color:var(--cream-dim);font-size:12px;font-weight:500;cursor:pointer;transition:all 0.2s;font-family:'Inter',sans-serif}
.btn-copy:hover{border-color:var(--gold);color:var(--gold)}

/* chat / recruiter chat */
.chat-wrap{padding:16px 20px}
.chat-msgs{display:flex;flex-direction:column;gap:12px;margin-bottom:16px;max-height:400px;overflow-y:auto}
.chat-msg{display:flex;gap:10px;align-items:flex-start}
.chat-msg.user{flex-direction:row-reverse}
.chat-avatar{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.avatar-ai{background:rgba(212,168,75,0.15);border:1px solid rgba(212,168,75,0.3)}
.avatar-user{background:var(--navy-3)}
.chat-bubble{max-width:82%;padding:10px 14px;border-radius:10px;font-size:13px;line-height:1.65}
.bubble-ai{background:var(--navy-2);border:1px solid var(--navy-3);color:var(--cream-dim)}
.bubble-user{background:rgba(212,168,75,0.12);border:1px solid rgba(212,168,75,0.2);color:var(--cream)}
.chat-input-row{display:flex;gap:8px}
.chat-input{flex:1;background:var(--navy-2);border:1px solid var(--navy-3);border-radius:8px;padding:10px 14px;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;outline:none;transition:border-color 0.2s}
.chat-input:focus{border-color:var(--gold)}
.chat-input::placeholder{color:var(--navy-4)}
.chat-send{padding:10px 16px;border-radius:8px;border:none;background:var(--gold);color:var(--navy);font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;font-family:'Inter',sans-serif}
.chat-send:hover{background:var(--gold-lt)}
.chat-send:disabled{opacity:0.4;cursor:not-allowed}
.typing{display:none;padding:8px 14px;background:var(--navy-2);border:1px solid var(--navy-3);border-radius:10px;width:fit-content}
.typing.show{display:block}
.typing span{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--muted);animation:bounce 1.2s infinite;margin:0 2px}
.typing span:nth-child(2){animation-delay:.2s}
.typing span:nth-child(3){animation-delay:.4s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

@media(max-width:580px){
  .metrics-row{grid-template-columns:1fr 1fr}
  .score-hero{flex-direction:column;text-align:center}
  .rec-scores{grid-template-columns:1fr}
  .results-nav{flex-wrap:wrap}
  .app{padding:32px 16px 80px}
}
</style>
</head>
<body>
<div class="app">

<header>
  <div class="wordmark"><div class="wdot"></div><span class="wtxt">ResumeIQ</span><div class="wdot"></div></div>
  <h1 class="hero-title">Your Resume.<br/><span>Analysed. Optimised. Recruited.</span></h1>
  <p class="hero-sub">ATS scoring · full resume optimisation · AI recruiter that thinks like a hiring manager</p>
</header>

<!-- MODE TOGGLE -->
<div class="mode-toggle">
  <button class="mode-btn active" id="modeAts" onclick="setMode('ats')">📊 ATS + Optimise</button>
  <button class="mode-btn" id="modeRec" onclick="setMode('recruiter')">🎯 AI Recruiter <span class="badge">NEW</span></button>
</div>

<!-- UPLOAD SECTION -->
<div id="uploadSection">

  <!-- Role -->
  <div class="role-section">
    <div class="divider"><div class="divider-line"></div><span class="divider-label">Target Role</span><div class="divider-line"></div></div>
    <div class="role-categories">
      <div>
        <div class="role-cat-label">Technology</div>
        <div class="role-grid">
